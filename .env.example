# Karyra Hub public frontend configuration.
# This file is safe to commit. Copy to .env for local development.

PUBLIC_HUB_APP_NAME="Karyra Hub"

# Hub can be served at /hub in the one-domain beta topology.
# Use an empty value only when Hub is served from the domain root.
PUBLIC_HUB_BASE_PATH="/hub"

# In one-domain topology, Spark lives at the same origin root.
# For separate local Spark development, use: http://localhost:5173
PUBLIC_SPARK_APP_URL="/"

# Optional read-only Starknet status check.
# Do not put private RPC credentials in PUBLIC_ variables.
PUBLIC_STARKNET_NETWORK="Starknet Sepolia"
# PUBLIC_STARKNET_RPC_URL="https://your-readonly-starknet-rpc.example/rpc/v0_7"
